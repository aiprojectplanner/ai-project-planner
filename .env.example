# OpenRouter API Key
OPENROUTER_API_KEY=your_api_key_here

# Single model (optional if OPENROUTER_MODELS is set)
OPENROUTER_MODEL=google/gemini-2.5-flash

# Comma-separated list, highest priority first. Server tries each until one succeeds.
# Example: OPENROUTER_MODELS=openai/gpt-4o-mini,deepseek/deepseek-chat-v3-0324,google/gemini-2.5-flash
OPENROUTER_MODELS=

SITE_URL=http://localhost:3000
SITE_NAME=AI Project Planner

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
